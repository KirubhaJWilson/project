{
  "version": 2,
  "builds": [
    {
      "src": "backend-node/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend-fastapi/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/api/node/:match*", "destination": "/backend-node/server.js" },
    { "source": "/api/ml/:match*", "destination": "/backend-fastapi/main.py" },
    { "source": "/((?!api/).*)", "destination": "/frontend/$1" }
  ]
}
